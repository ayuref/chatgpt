-- ============================================
--    CHARACTER CACHE
-- ============================================

local CC = {}

local function cacheC(p)
    local old = CC[p]
    if old and old.cn then
        for _, c in pairs(old.cn) do c:Disconnect() end
    end

    local ch = p.Character
    if not ch then CC[p] = nil; return end

    local hrp = ch:FindFirstChild("HumanoidRootPart")
    if not hrp then hrp = ch:WaitForChild("HumanoidRootPart", 5) end
    if not hrp then CC[p] = nil; return end

    local head = ch:FindFirstChild("Head")
    if not head then head = ch:WaitForChild("Head", 3) end

    local hum = ch:FindFirstChildOfClass("Humanoid")
    if not hum then hum = ch:WaitForChild("Humanoid", 3) end

    local d = {
        hrp = hrp, head = head, hum = hum,
        nm = p.DisplayName, tm = p.Team,
        alive = true, cn = {}, _valid = true
    }

    if d.hum then
        d.cn[1] = d.hum.Died:Connect(function() d.alive = false end)
    end
    d.cn[2] = p:GetPropertyChangedSignal("Team"):Connect(function()
        d.tm = p.Team
    end)
    d.cn[3] = ch.AncestryChanged:Connect(function()
        d._valid = false
    end)

    CC[p] = d
end

local function initP(p)
    if p == lp then return end
    if p.Character then task.spawn(cacheC, p) end
    p.CharacterAdded:Connect(function()
        task.spawn(cacheC, p)
    end)
end

for _, p in pairs(PS:GetPlayers()) do initP(p) end
PS.PlayerAdded:Connect(initP)

-- ============================================
--    WALLSHOT SYSTEM
-- ============================================

local wsActive = false
local wsParts  = {}
local wsConn   = nil

local function isPlayerPart(part)
    local m = part:FindFirstAncestorOfClass("Model")
    return m and PS:GetPlayerFromCharacter(m) ~= nil
end

local function wsSkip(part)
    if not part:IsA("BasePart") then return true end
    if part:IsA("Terrain") then return true end
    if part.Name == "Baseplate" then return true end
    if isPlayerPart(part) then return true end
    local sz = part.Size
    if sz.X < 1 and sz.Y < 1 and sz.Z < 1 then return true end
    return false
end

local function wsEnable()
    if wsActive then return end
    wsActive = true
    task.spawn(function()
        local desc = workspace:GetDescendants()
        local b = 0
        for _, part in pairs(desc) do
            if not wsActive then break end
            if not wsSkip(part) and part.CanQuery then
                wsParts[part] = true
                part.CanQuery = false
            end
            b = b + 1
            if b % 300 == 0 then task.wait() end
        end
    end)
    wsConn = workspace.DescendantAdded:Connect(function(part)
        if not wsActive then return end
        task.defer(function()
            if part and part.Parent and part:IsA("BasePart")
                and not wsSkip(part) and part.CanQuery then
                wsParts[part] = true
                part.CanQuery = false
            end
        end)
    end)
end

local function wsDisable()
    if not wsActive then return end
    wsActive = false
    if wsConn then wsConn:Disconnect(); wsConn = nil end
    task.spawn(function()
        local b = 0
        for part in pairs(wsParts) do
            if part and part.Parent then part.CanQuery = true end
            b = b + 1
            if b % 300 == 0 then task.wait() end
        end
        wsParts = {}
    end)
end

-- ============================================
--    TRIGGERBOT SYSTEM
-- ============================================

local tbFiring     = false
local tbLastFire   = 0
local tbHasTarget  = false

local function tbShoot()
    if tbFiring then return end
    local now = tick()
    if (now - tbLastFire) * 1000 < cfg.TBotDelay then return end

    tbFiring = true
    tbLastFire = now

    task.spawn(function()
        for i = 1, cfg.TBotBurst do
            if not cfg.TBot or not tbHasTarget then break end

            local ok1, _ = pcall(mouse1press)
            if ok1 then
                task.wait(cfg.TBotHoldTime / 1000)
                pcall(mouse1release)
            end

            if i < cfg.TBotBurst then
                task.wait(0.03)
            end
        end
        tbFiring = false
    end)
end

-- ============================================
--    RAYCASTS + CACHE VALIDATION (10Hz)
-- ============================================

local rayR = {}
local rayP = RaycastParams.new()
rayP.FilterType = Enum.RaycastFilterType.Exclude

task.spawn(function()
    while true do
        for _, p in pairs(PS:GetPlayers()) do
            if p ~= lp then
                local d = CC[p]
                local ch = p.Character

                if not d and ch then
                    task.spawn(cacheC, p)
                elseif d and not d._valid then
                    task.spawn(cacheC, p)
                elseif d and d.hrp and d.hrp.Parent == nil then
                    task.spawn(cacheC, p)
                elseif d and not d.alive and ch then
                    local hum = ch:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        task.spawn(cacheC, p)
                    end
                elseif d and d.head and d.head.Parent == nil then
                    if ch then
                        local nh = ch:FindFirstChild("Head")
                        if nh then d.head = nh end
                    end
                end
            end
        end

        if cfg.WC and (cfg.AimOn or cfg.ESPOn) then
            local mc = lp.Character
            if mc then
                rayP.FilterDescendantsInstances = {mc}
                local o = cam.CFrame.Position
                for p, d in pairs(CC) do
                    if d.alive and d._valid then
                        local pt = d.head or d.hrp
                        if pt and pt.Parent then
                            local r = workspace:Raycast(o, pt.Position - o, rayP)
                            if r then
                                local m = r.Instance:FindFirstAncestorOfClass("Model")
                                rayR[p] = (m ~= nil) and (PS:GetPlayerFromCharacter(m) ~= nil)
                            else
                                rayR[p] = true
                            end
                        end
                    end
                end
            end
        end

        task.wait(0.1)
    end
end)

