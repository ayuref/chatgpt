-- ============================================
--    RENDER LOOP
-- ============================================

local w2vp
local accumX = 0
local accumY = 0

-- triggerbot runs every 3 frames to save FPS
local tbFrame = 0
local TB_RATE = 3

RS.RenderStepped:Connect(function()
    cam = workspace.CurrentCamera
    w2vp = cam.WorldToViewportPoint
    mx = mse.X; my = mse.Y + giY

    local rawAim = false
    if cfg.AimOn then
        if not cfg.UseActKey then
            rawAim = true
        elseif actInfo == nil then
            rawAim = true
        else
            if aimMode == "Hold" then
                rawAim = actDown
            else
                if actDown and not wasDown then actToggled = not actToggled end
                wasDown = actDown; rawAim = actToggled
            end
        end
    end

    if prevRaw and not rawAim and cfg.Sleep > 0 then
        sleepUntil = tick() + cfg.Sleep / 1000
    end
    prevRaw = rawAim
    local shouldAim = rawAim or (not rawAim and tick() < sleepUntil)

    -- ═══ AIMBOT ═══
    if cfg.AimOn then
        if cfg.ShowFOV and fovC then
            fovC.Position = V2(mx, my)
            fovC.Radius = cfg.FOV
            fovC.Color = cfg.FOVCol
            fovC.Filled = cfg.FOVFill
            fovC.Visible = true
        elseif fovC then
            fovC.Visible = false
        end

        if shouldAim then
            aimFrm = aimFrm + 1
            if aimFrm >= AIM_RATE then
                aimFrm = 0
                aimTgt = findTarget()
            end

            if aimTgt then
                local sp = w2vp(cam, aimTgt)
                local tx, ty = sp.X, sp.Y

                accumX = accumX + (tx - mx) / cfg.Smooth
                accumY = accumY + (ty - my) / cfg.Smooth

                local moveX = 0
                local moveY = 0

                if accumX >= 1 then
                    moveX = floor(accumX)
                    accumX = accumX - moveX
                elseif accumX <= -1 then
                    moveX = -floor(-accumX)
                    accumX = accumX - moveX
                end

                if accumY >= 1 then
                    moveY = floor(accumY)
                    accumY = accumY - moveY
                elseif accumY <= -1 then
                    moveY = -floor(-accumY)
                    accumY = accumY - moveY
                end

                if moveX ~= 0 or moveY ~= 0 then
                    mousemoverel(moveX, moveY)
                end

                if cfg.ShowAL and aimL and aimD then
                    aimL.From = V2(mx, my); aimL.To = V2(tx, ty)
                    aimL.Color = cfg.AimCol; aimL.Visible = true
                    aimD.Position = V2(tx, ty); aimD.Color = cfg.AimCol; aimD.Visible = true
                else
                    if aimL then aimL.Visible = false end
                    if aimD then aimD.Visible = false end
                end
            else
                accumX = 0; accumY = 0
                if aimL then aimL.Visible = false end
                if aimD then aimD.Visible = false end
            end
        else
            aimTgt = nil; aimFrm = 0
            accumX = 0; accumY = 0
            if aimL then aimL.Visible = false end
            if aimD then aimD.Visible = false end
        end
    end

    -- ═══ TRIGGERBOT ═══
    if cfg.TBot then
        tbFrame = tbFrame + 1
        if tbFrame >= TB_RATE then
            tbFrame = 0
            tbHasTarget = hasFOVTarget()
            if tbHasTarget then
                tbShoot()
            end
        end
    end

    -- ═══ ESP ═══
    if not cfg.ESPOn or not anyFeat then
        dirty = false
        return
    end

    local focal = vsHY / tan(rad(cam.FieldOfView) * 0.5)
    local camP = cam.CFrame.Position
    local cpx, cpy, cpz = camP.X, camP.Y, camP.Z
    local maxDSq = cfg.MaxDist * cfg.MaxDist
    local doBox  = cfg.Box
    local do3D   = cfg.B3D
    local doTrc  = cfg.Trc
    local doHP   = cfg.HP
    local doName = cfg.Name
    local doDist = cfg.Dist
    local doLook = cfg.Look
    local isDirty = dirty

    local tfx, tfy
    if doTrc then
        local o = cfg.TrcFrom
        if o == "Bottom" then     tfx = vsHX; tfy = vsY
        elseif o == "Center" then tfx = vsHX; tfy = vsHY
        elseif o == "Top" then    tfx = vsHX; tfy = 0
        else                      tfx = mx;   tfy = my end
    end

    for player, e in pairs(EP) do
        local d = CC[player]

        if not d or not d.alive or not d._valid
            or not d.hrp or not d.hrp.Parent
            or not d.hum or not isE(d, cfg.ESPTeam) then
            hideE(e)
        else
            local hrp = d.hrp
            local pos = hrp.Position
            local ddx = pos.X - cpx
            local ddy = pos.Y - cpy
            local ddz = pos.Z - cpz
            local dSq = ddx * ddx + ddy * ddy + ddz * ddz

            if dSq > maxDSq then
                hideE(e)
            else
                local sp, on = w2vp(cam, pos)

                if not on then
                    hideE(e)
                else
                    local sx = floor(sp.X)
                    local sy = floor(sp.Y)
                    local pps = focal / sp.Z
                    local sh = floor(5.8 * pps)
                    local moved = (sx ~= e._sx) or (sy ~= e._sy) or (sh ~= e._sh)

                    if not moved and not isDirty and not e._hid then
                        -- skip
                    else
                        e._sx = sx; e._sy = sy; e._sh = sh; e._hid = false

                        local topY = sy - floor(3.0 * pps)
                        local botY = sy + floor(2.8 * pps)
                        local h = botY - topY
                        if h < 4 then h = 4 end
                        local w = floor(h * 0.5)
                        local bx = sx - floor(w * 0.5)

                        if doBox then
                            e.box.Position = V2(bx, topY)
                            e.box.Size = V2(w, h)
                            if isDirty or not e._bv then e.box.Color = cfg.BoxCol end
                            if not e._bv then e._bv = true; e.box.Visible = true end
                        else
                            if e._bv then e._bv = false; e.box.Visible = false end
                        end

                        if doTrc then
                            local fx, fy = tfx, tfy
                            if cfg.TrcFrom == "Mouse" then fx = mx; fy = my end
                            e.trc.From = V2(fx, fy)
                            e.trc.To = V2(sx, botY)
                            if isDirty or not e._tv then e.trc.Color = cfg.TrcCol end
                            if not e._tv then e._tv = true; e.trc.Visible = true end
                        else
                            if e._tv then e._tv = false; e.trc.Visible = false end
                        end

                        if doHP then
                            local hv = d.hum.Health
                            local mhp = d.hum.MaxHealth
                            local r = clamp(hv / mhp, 0, 1)
                            local hx = bx - 6
                            local col = hpC(r)

                            e.hpBG.From = V2(hx, topY)
                            e.hpBG.To = V2(hx, botY)
                            e.hpB.From = V2(hx, botY)
                            e.hpB.To = V2(hx, botY - floor(h * r))
                            e.hpB.Color = col

                            if not e._hv then
                                e._hv = true
                                e.hpBG.Visible = true
                                e.hpB.Visible = true
                            end
                        else
                            if e._hv then
                                e._hv = false
                                e.hpBG.Visible = false
                                e.hpB.Visible = false
                            end
                        end

                        if doName or doDist then
                            local txt = ""
                            if doName then txt = d.nm end
                            if doDist then
                                local dI = floor(dSq ^ 0.5)
                                if txt ~= "" then
                                    txt = txt .. " [" .. dI .. "m]"
                                else
                                    txt = dI .. "m"
                                end
                            end
                            if e._ltxt ~= txt then e._ltxt = txt; e.info.Text = txt end
                            e.info.Position = V2(sx, topY - 16)
                            if isDirty or not e._iv then e.info.Color = cfg.InfoCol end
                            if not e._iv then e._iv = true; e.info.Visible = true end
                        else
                            if e._iv then e._iv = false; e.info.Visible = false end
                        end

                        if doLook and d.head and d.head.Parent then
                            local headP = d.head.Position
                            local le = headP + d.head.CFrame.LookVector * 10
                            local hs = w2vp(cam, headP)
                            local ls = w2vp(cam, le)
                            e.lk.From = V2(floor(hs.X), floor(hs.Y))
                            e.lk.To = V2(floor(ls.X), floor(ls.Y))
                            if isDirty or not e._lv then e.lk.Color = cfg.LookCol end
                            if not e._lv then e._lv = true; e.lk.Visible = true end
                        else
                            if e._lv then e._lv = false; e.lk.Visible = false end
                        end

                        if do3D then
                            local cf = hrp.CFrame
                            local allOn = true
                            for i = 1, 8 do
                                local s, onn = w2vp(cam, (cf * b3off[i]).Position)
                                if not onn then allOn = false; break end
                                scX[i] = floor(s.X); scY[i] = floor(s.Y)
                            end
                            if allOn then
                                local c3 = cfg.B3DCol
                                for i = 1, 12 do
                                    local a, b = b3e[i][1], b3e[i][2]
                                    e.b3[i].From = V2(scX[a], scY[a])
                                    e.b3[i].To = V2(scX[b], scY[b])
                                    if isDirty or not e._3v then e.b3[i].Color = c3 end
                                    e.b3[i].Visible = true
                                end
                                e._3v = true
                            else
                                if e._3v then
                                    e._3v = false
                                    for i = 1, 12 do e.b3[i].Visible = false end
                                end
                            end
                        else
                            if e._3v then
                                e._3v = false
                                for i = 1, 12 do e.b3[i].Visible = false end
                            end
                        end
                    end
                end
            end
        end
    end

    dirty = false
end)

