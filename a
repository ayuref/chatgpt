-- ============================================
--    AIMBOT TARGET
-- ============================================

local aimTgt = nil
local aimFrm = 0
local AIM_RATE = 2

local function findTarget()
    local best = nil
    local bestDSq = cfg.FOV * cfg.FOV
    local w = cam.WorldToViewportPoint

    for p, d in pairs(CC) do
        if d.alive and d._valid and d.hrp and d.hrp.Parent and isE(d, cfg.AimTeam) then
            local pt = (cfg.AimPart == "Head") and d.head or d.hrp
            if pt and pt.Parent then
                local pos = pt.Position
                if cfg.Pred > 0 and d.hrp then
                    local vel = d.hrp.AssemblyLinearVelocity
                    pos = V3(pos.X + vel.X * cfg.Pred, pos.Y + vel.Y * cfg.Pred, pos.Z + vel.Z * cfg.Pred)
                end
                local sp, on = w(cam, pos)
                if on then
                    local ddx = sp.X - mx
                    local ddy = sp.Y - my
                    local dq = ddx * ddx + ddy * ddy
                    if dq < bestDSq then
                        if not cfg.WC or rayR[p] ~= false then
                            bestDSq = dq; best = pos
                        end
                    end
                end
            end
        end
    end
    return best
end

-- triggerbot target check (is anyone in FOV?)
local function hasFOVTarget()
    local fovSq = cfg.FOV * cfg.FOV
    for p, d in pairs(CC) do
        if d.alive and d._valid and d.hrp and d.hrp.Parent and isE(d, cfg.AimTeam) then
            local pt = (cfg.AimPart == "Head") and d.head or d.hrp
            if pt and pt.Parent then
                local sp, on = cam:WorldToViewportPoint(pt.Position)
                if on then
                    local ddx = sp.X - mx
                    local ddy = sp.Y - my
                    if ddx * ddx + ddy * ddy < fovSq then
                        if not cfg.WC or rayR[p] ~= false then
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

