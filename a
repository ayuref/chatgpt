        for i = 1, 12 do
            e.b3[i] = Drawing.new("Line")
            e.b3[i].Thickness = 1; e.b3[i].Visible = false
        end

        e._hid = true
        e._sx = -999; e._sy = -999; e._sh = -999
        e._ltxt = ""
        e._bv = false; e._tv = false; e._hv = false
        e._iv = false; e._lv = false; e._3v = false
    end)
    EP[p] = e
end

local function rmE(p)
    local e = EP[p]
    if not e then return end
    pcall(function()
        e.box:Remove(); e.trc:Remove()
        e.hpBG:Remove(); e.hpB:Remove()
        e.info:Remove(); e.lk:Remove()
        for i = 1, 12 do e.b3[i]:Remove() end
    end)
    EP[p] = nil
end

local function hideE(e)
    if e._hid then return end
    e._hid = true; e._sx = -999; e._sy = -999; e._sh = -999
    if e._bv then e._bv = false; e.box.Visible = false end
    if e._tv then e._tv = false; e.trc.Visible = false end
    if e._hv then e._hv = false; e.hpBG.Visible = false; e.hpB.Visible = false end
    if e._iv then e._iv = false; e.info.Visible = false end
    if e._lv then e._lv = false; e.lk.Visible = false end
    if e._3v then e._3v = false; for i = 1, 12 do e.b3[i].Visible = false end end
end

local function hideAllE()
    for _, e in pairs(EP) do hideE(e) end
end

